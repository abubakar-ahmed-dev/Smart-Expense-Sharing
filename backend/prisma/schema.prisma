generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// DOMAIN MODELS FOR PHASE 2
// Money is stored in minor units (cents) as Int
// ============================================

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  phones            UserPhone[]
  groupMemberships  GroupMember[]
  expensesPaidBy    Expense[]       @relation("PaidBy")
  expenseShares     ExpenseShare[]
  settlementsFrom   Settlement[]    @relation("FromUser")
  settlementsTo     Settlement[]    @relation("ToUser")
  ledgerFromUser    LedgerEntry[]   @relation("FromUserLedger")
  ledgerToUser      LedgerEntry[]   @relation("ToUserLedger")
}

model UserPhone {
  id        String   @id @default(cuid())
  userId    String
  number    String
  label     String?  // e.g., "mobile", "home"
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, number])
  @@index([userId])
}

model Group {
  id        String          @id @default(cuid())
  name      String
  createdBy String          // userId
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relations
  members           GroupMember[]
  expenses          Expense[]
  settlements       Settlement[]
  ledgerEntries     LedgerEntry[]
  pairBalances      PairBalance[]
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("MEMBER") // ADMIN | MEMBER
  joinedAt  DateTime @default(now())
  isActive  Boolean  @default(true)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model Expense {
  id           String          @id @default(cuid())
  groupId      String
  paidByUserId String
  totalAmount  Int             // in minor units (cents)
  currency     String          @default("USD")
  description  String
  splitType    String          @default("EQUAL") // EQUAL | EXACT | PERCENTAGE
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  group         Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy        User            @relation("PaidBy", fields: [paidByUserId], references: [id], onDelete: Restrict)
  shares        ExpenseShare[]
  ledgerEntries LedgerEntry[]

  @@index([groupId])
  @@index([paidByUserId])
  @@index([createdAt])
}

model ExpenseShare {
  id         String   @id @default(cuid())
  expenseId  String
  userId     String
  amountOwed Int      // in minor units (cents)
  createdAt  DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
}

model Settlement {
  id         String       @id @default(cuid())
  groupId    String
  fromUserId String
  toUserId   String
  amount     Int          // in minor units (cents)
  createdAt  DateTime     @default(now())

  group       Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser    User          @relation("FromUser", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser      User          @relation("ToUser", fields: [toUserId], references: [id], onDelete: Restrict)
  ledgerEntry LedgerEntry?

  @@index([groupId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
}

model LedgerEntry {
  id           String   @id @default(cuid())
  groupId      String
  eventType    String   // EXPENSE | SETTLEMENT
  fromUserId   String
  toUserId     String
  amount       Int      // in minor units (cents)
  referenceId  String   // expenseId or settlementId
  expenseId    String?
  settlementId String?  @unique
  createdAt    DateTime @default(now())

  group    Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser User         @relation("FromUserLedger", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser   User         @relation("ToUserLedger", fields: [toUserId], references: [id], onDelete: Restrict)
  expense  Expense?     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  settlement Settlement? @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
}

model PairBalance {
  id             String   @id @default(cuid())
  groupId        String
  debtorUserId   String
  creditorUserId String
  netAmount      Int      // in minor units (cents) - positive = debtor owes creditor
  updatedAt      DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, debtorUserId, creditorUserId])
  @@index([groupId])
  @@index([debtorUserId])
  @@index([creditorUserId])
}
